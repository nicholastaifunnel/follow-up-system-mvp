# Neon pooled connection string for app runtime / Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# Neon direct connection string for Prisma db push / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# DATABASE_URL is used by Vercel / app runtime.
# DIRECT_URL is used by Prisma db push / migration.
# If Neon provides separate pooled and direct strings, put the real values in
# local .env and Vercel Environment Variables. Do not commit real credentials.

# Internal password gate for /queues, /import, /leads/*, /reply-sop, /skipped-leads.
# When both are set, middleware requires a valid httpOnly session cookie from /login.
# Use a long random string for AUTH_COOKIE_SECRET (e.g. openssl rand -hex 32).
APP_PASSWORD=
AUTH_COOKIE_SECRET=
